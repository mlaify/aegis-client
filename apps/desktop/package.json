{
  "name": "aegis-desktop",
  "private": true,
  "version": "0.0.0",
  "description": "Aegis desktop client — Electron shell wrapping the aegis-web renderer with OS notifications, dock badge, system tray, OS keychain (safeStorage), and native file pickers.",
  "main": "dist-electron/main.js",
  "type": "commonjs",
  "scripts": {
    "build:electron": "tsc -p tsconfig.json",
    "build:renderer": "npm --prefix ../web run build && rm -rf dist-renderer && cp -R ../web/dist dist-renderer",
    "build": "npm run build:renderer && npm run build:electron",
    "dev:electron": "tsc -p tsconfig.json --watch --preserveWatchOutput",
    "dev:run": "wait-on tcp:5173 && electron .",
    "dev": "npm run build:electron && AEGIS_DESKTOP_DEV=1 AEGIS_DESKTOP_RENDERER_URL=http://localhost:5173 electron .",
    "start": "electron .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "package": "npm run build && electron-builder",
    "package:mac": "npm run build && electron-builder --mac",
    "package:win": "npm run build && electron-builder --win",
    "package:linux": "npm run build && electron-builder --linux"
  },
  "dependencies": {
    "electron-updater": "^6.3.9"
  },
  "devDependencies": {
    "@types/node": "^22.19.17",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8",
    "typescript": "^5.6.2",
    "wait-on": "^8.0.1"
  }
}
